    "utf-8-validate": "^5.0.10",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-builders/custom-esbuild": "^21.0.3",
    "@angular-builders/jest": "^21.0.3",
    "@angular-eslint/builder": "^21.3.0",
    "@angular-eslint/eslint-plugin": "^21.3.0",
